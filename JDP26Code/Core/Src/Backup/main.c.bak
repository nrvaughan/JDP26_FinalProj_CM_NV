/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_DMA_Init();
  MX_ADC1_Init();
  MX_DAC1_Init();
  MX_TIM6_Init();
  MX_USART2_UART_Init();
  MX_TIM2_Init();
  MX_TIM3_Init();
  /* USER CODE BEGIN 2 */

    /* Encoder/PWMs */
  HAL_GPIO_WritePin(GPIOB, GPIO_PIN_0, GPIO_PIN_SET);
  HAL_TIM_PWM_Start(&htim3, TIM_CHANNEL_1);  // PB4, PWM1
  __HAL_TIM_SET_COMPARE(&htim3, TIM_CHANNEL_1, 2475);
  HAL_TIM_PWM_Start(&htim2, TIM_CHANNEL_3);  // PB10, PWM2
  __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_3, 2630);

  /* ADC + DAC  */
  HAL_DAC_Start(&hdac1, DAC_CHANNEL_1);
  HAL_ADCEx_Calibration_Start(&hadc1, ADC_SINGLE_ENDED);
  HAL_ADC_Start_DMA(&hadc1, (uint32_t*)adcBuffer, ADC_BUF_LEN);
  HAL_TIM_Base_Start_IT(&htim6);

  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  /* USER CODE BEGIN WHILE */
while (1) /* this loop handles chaning PWM via rotary encoder */
{
  static uint8_t lastA = 0;
  static uint8_t initialized = 0;
  static uint32_t lastStepTime = 0;

  uint8_t A = (HAL_GPIO_ReadPin(GPIOC, GPIO_PIN_7) == GPIO_PIN_SET) ? 1 : 0;
  uint8_t B = (HAL_GPIO_ReadPin(GPIOB, GPIO_PIN_6) == GPIO_PIN_SET) ? 1 : 0;

  if (!initialized)
  {
    lastA = A;
    initialized = 1;
  }

  if ((HAL_GetTick() - lastStepTime) > 50)
  {
    if ((lastA == 0) && (A == 1))
    {
      lastStepTime = HAL_GetTick();

      if (B == 0)
      {
        if (freqInd < 15) freqInd++;
      }
      else
      {
        if (freqInd > 0) freqInd--;
      }

      __HAL_TIM_SET_COMPARE(&htim3, TIM_CHANNEL_1, pwm1Dutys[freqInd]);
      __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_3, pwm2Dutys[freqInd]);
    }
  }

  lastA = A;
}

    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */

  /* USER CODE END 3 */
}

/**
  * @brief System Clock Configuration
  * @retval None
  */
void SystemClock_Config(void)
{
  RCC_OscInitTypeDef RCC_OscInitStruct = {0};
  RCC_ClkInitTypeDef RCC_ClkInitStruct = {0};
  RCC_PeriphCLKInitTypeDef PeriphClkInit = {0};

  /** Initializes the RCC Oscillators according to the specified parameters
  * in the RCC_OscInitTypeDef structure.
  */
  RCC_OscInitStruct.OscillatorType = RCC_OSCILLATORTYPE_HSI;
  RCC_OscInitStruct.HSIState = RCC_HSI_ON;
  RCC_OscInitStruct.HSICalibrationValue = RCC_HSICALIBRATION_DEFAULT;
  RCC_OscInitStruct.PLL.PLLState = RCC_PLL_ON;
  RCC_OscInitStruct.PLL.PLLSource = RCC_PLLSOURCE_HSI;
  RCC_OscInitStruct.PLL.PLLMUL = RCC_PLL_MUL9;
  RCC_OscInitStruct.PLL.PREDIV = RCC_PREDIV_DIV1;
  if (HAL_RCC_OscConfig(&RCC_OscInitStruct) != HAL_OK)
  {
    Error_Handler();
  }

  /** Initializes the CPU, AHB and APB buses clocks
  */
  RCC_ClkInitStruct.ClockType = RCC_CLOCKTYPE_HCLK|RCC_CLOCKTYPE_SYSCLK
                              |RCC_CLOCKTYPE_PCLK1|RCC_CLOCKTYPE_PCLK2;
  RCC_ClkInitStruct.SYSCLKSource = RCC_SYSCLKSOURCE_PLLCLK;
  RCC_ClkInitStruct.AHBCLKDivider = RCC_SYSCLK_DIV1;
  RCC_ClkInitStruct.APB1CLKDivider = RCC_HCLK_DIV2;
  RCC_ClkInitStruct.APB2CLKDivider = RCC_HCLK_DIV1;

  if (HAL_RCC_ClockConfig(&RCC_ClkInitStruct, FLASH_LATENCY_2) != HAL_OK)
  {
    Error_Handler();
  }
  PeriphClkInit.PeriphClockSelection = RCC_PERIPHCLK_USART2|RCC_PERIPHCLK_ADC12
                              |RCC_PERIPHCLK_TIM2|RCC_PERIPHCLK_TIM34;
  PeriphClkInit.Usart2ClockSelection = RCC_USART2CLKSOURCE_PCLK1;
  PeriphClkInit.Adc12ClockSelection = RCC_ADC12PLLCLK_DIV1;
  PeriphClkInit.Tim2ClockSelection = RCC_TIM2CLK_HCLK;
  PeriphClkInit.Tim34ClockSelection = RCC_TIM34CLK_HCLK;
  if (HAL_RCCEx_PeriphCLKConfig(&PeriphClkInit) != HAL_OK)
  {
    Error_Handler();
  }
}

/* USER CODE BEGIN 4 */
/* USER CODE BEGIN 4 */

/* USER CODE BEGIN 4 */

/* Two first two functions simply */

void HAL_ADC_ConvHalfCpltCallback(ADC_HandleTypeDef* hadc)
{
  if (hadc->Instance == ADC1)
  {
    halfCount++;
    adcHalfReady = 1;
  }
}

void HAL_ADC_ConvCpltCallback(ADC_HandleTypeDef* hadc)
{
  if (hadc->Instance == ADC1)
  {
    fullCount++;
    adcFullReady = 1;
  }
}

void HAL_TIM_PeriodElapsedCallback(TIM_HandleTypeDef *htim)
{
  if (htim->Instance == TIM6)
  {
    uint32_t dmaRemaining = __HAL_DMA_GET_COUNTER(hadc1.DMA_Handle);
    uint32_t writeIndex = ADC_BUF_LEN - dmaRemaining;
  
    if (writeIndex >= ADC_BUF_LEN)
    {
      writeIndex = 0;
    }

    uint32_t readIndex;

    if (writeIndex >= 2) 
    {
      readIndex = writeIndex - 2; 
    }
    else
    {
      readIndex = ADC_BUF_LEN - 2;
    }

    // Ensure readIndex points to mic sample, even index
    if (readIndex % 2 != 0)
    {
      readIndex--;
    }

    uint16_t micRaw = adcBuffer[readIndex];       // PA0
    uint16_t auxRaw = adcBuffer[readIndex + 1];   // PA1

    int32_t micAC = (int32_t)micRaw - 2056; // removing DC offsets
    int32_t auxAC = (int32_t)auxRaw - 2033; 

    // mic + aux gain
    int32_t micScaled = micAC;
    int32_t auxScaled = auxAC / 4;

    int32_t mixedAC = micScaled + auxScaled;
    int32_t dacOut = 2048 + mixedAC; // adding back DC offset for output

    if (dacOut < 0) dacOut = 0;
    if (dacOut > 4095) dacOut = 4095; // clipping

    HAL_DAC_SetValue(&hdac1, DAC_CHANNEL_1, DAC_ALIGN_12B_R, (uint32_t)dacOut); // DAC Output on PA4
  }
}

